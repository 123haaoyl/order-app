.page {
  padding: 20rpx;
}

.page-head,
.order-head,
.order-foot,
.line {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.page-head {
  margin-bottom: 18rpx;
}

.eyebrow {
  color: #28775c;
  font-size: 24rpx;
  font-weight: 700;
}

.title {
  font-size: 42rpx;
  font-weight: 900;
}

.order-list {
  display: grid;
  gap: 14rpx;
}

.order-card,
.empty {
  border: 1rpx solid #ded8ca;
  border-radius: 16rpx;
  background: #fffdf8;
  padding: 20rpx;
}

.order-id,
.order-target,
.total {
  font-weight: 900;
}

.status {
  border: 1rpx solid rgba(40, 119, 92, 0.28);
  border-radius: 999rpx;
  color: #28775c;
  padding: 6rpx 14rpx;
  font-size: 24rpx;
  white-space: nowrap;
}

.lines {
  display: grid;
  gap: 8rpx;
  margin: 18rpx 0;
  color: #706c63;
  font-size: 26rpx;
}

.order-foot {
  border-top: 1rpx solid #ded8ca;
  color: #706c63;
  font-size: 24rpx;
  padding-top: 12rpx;
}

.total {
  color: #9f2f20;
  font-size: 32rpx;
}

.empty {
  display: grid;
  gap: 20rpx;
  justify-items: center;
  color: #706c63;
}
