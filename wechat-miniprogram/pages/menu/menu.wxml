<view class="page theme-{{theme}}">
  <view class="shop-head">
    <view>
      <view class="shop-title">{{shop.name}}</view>
      <view class="shop-subtitle">{{shop.subtitle}}</view>
    </view>
    <view class="head-actions">
      <button class="theme-toggle" bindtap="toggleTheme">{{theme === 'dark' ? '浅色' : '深色'}}</button>
      <view class="shop-badge">月售热榜</view>
    </view>
  </view>

  <view class="top-tools">
    <view class="mode-tabs">
      <button class="{{orderType === 'dinein' ? 'active' : ''}}" bindtap="setOrderType" data-type="dinein">到店</button>
      <button class="{{orderType === 'takeaway' ? 'active' : ''}}" bindtap="setOrderType" data-type="takeaway">外卖</button>
    </view>
    <view class="search-box">
      <input value="{{keyword}}" placeholder="搜索菜品" bindinput="inputKeyword" />
    </view>
  </view>

  <view class="menu-shell">
    <scroll-view class="category-rail" scroll-y>
      <view
        wx:for="{{categories}}"
        wx:key="*this"
        class="category-item {{item === activeCategory ? 'active' : ''}}"
        bindtap="setCategory"
        data-category="{{item}}"
      >
        <text>{{item}}</text>
      </view>
    </scroll-view>

    <scroll-view class="dish-scroll" scroll-y>
      <view class="dish-section-head">
        <view>
          <view class="section-title">{{activeCategory}}</view>
          <view class="section-subtitle">共 {{filteredCount}} 个菜品</view>
        </view>
        <view class="sort-chip">按推荐</view>
      </view>

      <view class="dish-list">
        <view wx:for="{{filteredItems}}" wx:key="id" class="dish-card">
          <view class="dish-icon">{{item.image || '🍽️'}}</view>
          <view class="dish-main">
            <view class="dish-name">{{item.name}}</view>
            <view class="dish-desc">{{item.description}}</view>
            <view class="dish-meta">
              <text>月售 {{item.monthlySales || 0}}</text>
              <text>库存 {{item.stock}}</text>
            </view>
            <view class="dish-bottom">
              <view>
                <text class="price">¥{{item.price}}</text>
                <text wx:if="{{item.tag}}" class="dish-tag">{{item.tag}}</text>
              </view>
              <button class="add-button" bindtap="openSpec" data-id="{{item.id}}" disabled="{{item.stock <= 0}}">
                {{item.stock <= 0 ? '售罄' : '选规格'}}
              </button>
            </view>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="cart-bar" bindtap="openCartPanel">
    <view class="cart-bubble">
      <text>🛒</text>
      <view wx:if="{{totals.count}}" class="cart-count">{{totals.count}}</view>
    </view>
    <view class="cart-summary">
      <view class="cart-price">¥{{totals.payable}}</view>
      <view class="cart-tip">{{totals.count ? '已选 ' + totals.count + ' 件' : '未选购商品'}}</view>
    </view>
    <button class="checkout-button" catchtap="goCheckout" disabled="{{!totals.count}}">去结算</button>
  </view>

  <view wx:if="{{cartPanelVisible}}" class="cart-mask" bindtap="closeCartPanel">
    <view class="cart-panel" catchtap="noop">
      <view class="cart-panel-head">
        <text>购物车</text>
        <button size="mini" bindtap="clearCart">清空</button>
      </view>
      <view wx:if="{{cartItems.length}}" class="cart-list">
        <view wx:for="{{cartItems}}" wx:key="key" class="cart-row">
          <view class="cart-info">
            <view class="cart-name">{{item.image}} {{item.name}}</view>
            <view class="cart-spec">{{item.specText}}</view>
            <view class="cart-price-line">¥{{item.unitPrice * item.quantity}}</view>
          </view>
          <view class="cart-actions">
            <button class="delete-button" size="mini" data-key="{{item.key}}" bindtap="removeCartItem">删除</button>
            <button class="qty-button" size="mini" data-key="{{item.key}}" bindtap="decreaseCart">-</button>
            <text class="qty-text">{{item.quantity}}</text>
            <button class="qty-button" size="mini" data-key="{{item.key}}" bindtap="increaseCart">+</button>
          </view>
        </view>
      </view>
      <view wx:else class="cart-empty">购物车是空的</view>
      <view class="cart-panel-foot">
        <view>
          <view class="cart-price">¥{{totals.payable}}</view>
          <view class="cart-tip">共 {{totals.count}} 件</view>
        </view>
        <button class="checkout-button" bindtap="goCheckout" disabled="{{!totals.count}}">去结算</button>
      </view>
    </view>
  </view>

  <view wx:if="{{specVisible}}" class="modal-mask" bindtap="closeSpec">
    <view class="spec-modal" catchtap="noop">
      <view class="modal-head">
        <view>
          <view class="modal-title">{{selectedDish.image}} {{selectedDish.name}}</view>
          <view class="modal-subtitle">{{selectedDish.description}}</view>
        </view>
        <button size="mini" bindtap="closeSpec">×</button>
      </view>
      <view wx:for="{{selectedDish.specs}}" wx:key="name" wx:for-index="groupIndex" class="spec-group">
        <view class="field-label">{{item.name}}</view>
        <view class="spec-options">
          <button
            wx:for="{{item.options}}"
            wx:key="label"
            wx:for-item="option"
            wx:for-index="optionIndex"
            class="{{selectedSpecIndexes[groupIndex] === optionIndex ? 'active' : ''}}"
            data-group="{{groupIndex}}"
            data-option="{{optionIndex}}"
            bindtap="selectSpec"
          >
            {{option.label}}{{option.priceDelta ? ' +' + option.priceDelta : ''}}
          </button>
        </view>
      </view>
      <button class="add-configured" bindtap="addSelectedDish">加入购物车 · ¥{{selectedPrice}}</button>
    </view>
  </view>
</view>
