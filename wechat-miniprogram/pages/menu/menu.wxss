.page {
  min-height: 100vh;
  padding-bottom: 132rpx;
  background: #f6f4ef;
}

.shop-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  padding: 24rpx 24rpx 18rpx;
  background: linear-gradient(180deg, #fff7ed, #f6f4ef);
}

.shop-title {
  font-size: 42rpx;
  font-weight: 900;
}

.shop-subtitle,
.section-subtitle,
.dish-desc,
.dish-meta,
.cart-tip,
.cart-spec,
.modal-subtitle,
.field-label {
  color: #706c63;
  font-size: 24rpx;
}

.shop-badge,
.sort-chip {
  flex: 0 0 auto;
  border-radius: 999rpx;
  background: #fff;
  color: #c7442e;
  font-size: 22rpx;
  font-weight: 800;
  padding: 8rpx 14rpx;
}

.top-tools {
  display: grid;
  grid-template-columns: 180rpx minmax(0, 1fr);
  gap: 14rpx;
  padding: 0 20rpx 16rpx;
}

.mode-tabs {
  display: grid;
  grid-template-columns: 1fr 1fr;
  overflow: hidden;
  border-radius: 999rpx;
  background: #ebe4d8;
  padding: 4rpx;
}

.mode-tabs button {
  min-height: 56rpx;
  border: 0;
  border-radius: 999rpx;
  background: transparent;
  color: #706c63;
  font-size: 24rpx;
}

.mode-tabs button.active {
  background: #c7442e;
  color: #fff;
}

.search-box {
  display: grid;
  align-items: center;
  min-height: 64rpx;
  border-radius: 999rpx;
  background: #fff;
  padding: 0 22rpx;
}

.search-box input {
  font-size: 26rpx;
}

.menu-shell {
  display: grid;
  grid-template-columns: 164rpx minmax(0, 1fr);
  height: calc(100vh - 226rpx);
  min-height: 720rpx;
  border-top: 1rpx solid #eadfce;
  background: #fffdf8;
}

.category-rail {
  height: 100%;
  background: #f3eee5;
}

.category-item {
  position: relative;
  display: flex;
  align-items: center;
  min-height: 92rpx;
  padding: 0 16rpx;
  color: #5f594f;
  font-size: 25rpx;
  font-weight: 700;
}

.category-item.active {
  background: #fffdf8;
  color: #c7442e;
}

.category-item.active::before {
  position: absolute;
  left: 0;
  width: 8rpx;
  height: 36rpx;
  border-radius: 999rpx;
  background: #c7442e;
  content: "";
}

.dish-scroll {
  height: 100%;
  background: #fffdf8;
}

.dish-section-head {
  position: sticky;
  top: 0;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  background: #fffdf8;
  padding: 18rpx 18rpx 12rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 900;
}

.dish-list {
  display: grid;
  gap: 2rpx;
  padding: 0 18rpx 20rpx;
}

.dish-card {
  display: grid;
  grid-template-columns: 132rpx minmax(0, 1fr);
  gap: 16rpx;
  border-bottom: 1rpx solid #f0e6d8;
  padding: 18rpx 0;
}

.dish-icon {
  display: grid;
  width: 132rpx;
  height: 132rpx;
  place-items: center;
  border-radius: 16rpx;
  background: #f4efe4;
  font-size: 54rpx;
}

.dish-main {
  display: grid;
  min-width: 0;
  gap: 8rpx;
}

.dish-name {
  font-size: 29rpx;
  font-weight: 900;
  line-height: 1.25;
}

.dish-desc {
  display: -webkit-box;
  overflow: hidden;
  line-height: 1.35;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.dish-meta {
  display: flex;
  gap: 12rpx;
}

.dish-bottom {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 10rpx;
}

.price,
.cart-price {
  color: #c7442e;
  font-size: 34rpx;
  font-weight: 900;
}

.dish-tag {
  margin-left: 8rpx;
  border-radius: 999rpx;
  background: #fff1ed;
  color: #c7442e;
  font-size: 20rpx;
  font-weight: 700;
  padding: 3rpx 8rpx;
}

.add-button {
  min-width: 104rpx;
  min-height: 54rpx;
  border: 0;
  border-radius: 999rpx;
  background: #c7442e;
  color: #fff;
  font-size: 24rpx;
}

.pager {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  color: #706c63;
  font-size: 24rpx;
  padding: 10rpx 0 28rpx;
}

.cart-bar {
  position: fixed;
  right: 20rpx;
  bottom: 22rpx;
  left: 20rpx;
  z-index: 10;
  display: grid;
  grid-template-columns: 92rpx minmax(0, 1fr) 188rpx;
  align-items: center;
  gap: 16rpx;
  min-height: 96rpx;
  border-radius: 999rpx;
  background: #211f1b;
  box-shadow: 0 16rpx 42rpx rgba(43, 35, 24, 0.22);
  padding: 10rpx 12rpx;
}

.cart-bubble {
  position: relative;
  display: grid;
  width: 76rpx;
  height: 76rpx;
  place-items: center;
  border-radius: 999rpx;
  background: #c7442e;
  color: #fff;
  font-size: 34rpx;
}

.cart-count {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 30rpx;
  height: 30rpx;
  border-radius: 999rpx;
  background: #fff;
  color: #c7442e;
  font-size: 20rpx;
  font-weight: 900;
  line-height: 30rpx;
  text-align: center;
}

.cart-summary {
  min-width: 0;
}

.cart-tip {
  color: #cfc7bb;
}

.checkout-button {
  min-height: 72rpx;
  border: 0;
  border-radius: 999rpx;
  background: #f4c15d;
  color: #211f1b;
  font-size: 28rpx;
  font-weight: 900;
}

.cart-mask,
.modal-mask {
  position: fixed;
  inset: 0;
  z-index: 20;
  display: flex;
  align-items: flex-end;
  background: rgba(0, 0, 0, 0.45);
}

.cart-panel,
.spec-modal {
  width: 100%;
  max-height: 78vh;
  overflow-y: auto;
  border-radius: 28rpx 28rpx 0 0;
  background: #fffdf8;
  padding: 24rpx;
}

.cart-panel-head,
.cart-row,
.cart-actions,
.modal-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.cart-row {
  border-bottom: 1rpx solid #eadfce;
  padding: 16rpx 0;
}

.cart-name {
  font-weight: 900;
}

.spec-group {
  margin-bottom: 18rpx;
}

.modal-head {
  align-items: flex-start;
  margin-bottom: 18rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 900;
}

.spec-options {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
  margin-top: 10rpx;
}

.spec-options button {
  min-height: 64rpx;
  border: 1rpx solid #ded8ca;
  background: #fff;
}

.spec-options button.active {
  border-color: #c7442e;
  background: #c7442e;
  color: #fff;
}

.add-configured {
  width: 100%;
  min-height: 84rpx;
  border: 0;
  border-radius: 16rpx;
  background: #c7442e;
  color: #fff;
  font-weight: 900;
}
