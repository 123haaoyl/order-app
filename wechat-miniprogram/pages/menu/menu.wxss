.page {
  min-height: 100vh;
  padding-bottom: 132rpx;
  background: #f6f4ef;
  color: #211f1b;
}

.shop-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  padding: 24rpx 24rpx 18rpx;
  background: linear-gradient(180deg, #fff7ed, #f6f4ef);
}

.shop-title {
  font-size: 42rpx;
  font-weight: 900;
}

.head-actions {
  display: flex;
  flex: 0 0 auto;
  align-items: center;
  gap: 10rpx;
}

.theme-toggle {
  min-width: 88rpx;
  min-height: 52rpx;
  margin: 0;
  border: 1rpx solid rgba(33, 31, 27, 0.16);
  border-radius: 999rpx;
  background: #211f1b;
  color: #fffaf2;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 52rpx;
  padding: 0 16rpx;
}

.theme-toggle::after {
  border: 0;
}

.shop-subtitle,
.section-subtitle,
.dish-desc,
.dish-meta,
.cart-tip,
.cart-spec,
.modal-subtitle,
.field-label {
  color: #706c63;
  font-size: 24rpx;
}

.shop-badge,
.sort-chip {
  flex: 0 0 auto;
  border-radius: 999rpx;
  background: #fff;
  color: #c7442e;
  font-size: 22rpx;
  font-weight: 800;
  padding: 8rpx 14rpx;
}

.top-tools {
  display: grid;
  grid-template-columns: 180rpx minmax(0, 1fr);
  gap: 14rpx;
  padding: 0 20rpx 16rpx;
}

.mode-tabs {
  display: grid;
  grid-template-columns: 1fr 1fr;
  overflow: hidden;
  border-radius: 999rpx;
  background: #ebe4d8;
  padding: 4rpx;
}

.mode-tabs button {
  min-height: 56rpx;
  border: 0;
  border-radius: 999rpx;
  background: transparent;
  color: #706c63;
  font-size: 24rpx;
}

.mode-tabs button.active {
  background: #c7442e;
  color: #fff;
}

.search-box {
  display: grid;
  align-items: center;
  min-height: 64rpx;
  border-radius: 999rpx;
  background: #fff;
  padding: 0 22rpx;
}

.search-box input {
  font-size: 26rpx;
}

.menu-shell {
  display: grid;
  grid-template-columns: 164rpx minmax(0, 1fr);
  height: calc(100vh - 226rpx);
  min-height: 720rpx;
  border-top: 1rpx solid #eadfce;
  background: #fffdf8;
}

.category-rail {
  height: 100%;
  background: #f3eee5;
}

.category-item {
  position: relative;
  display: flex;
  align-items: center;
  min-height: 92rpx;
  padding: 0 16rpx;
  color: #5f594f;
  font-size: 25rpx;
  font-weight: 700;
}

.category-item.active {
  background: #fffdf8;
  color: #c7442e;
}

.category-item.active::before {
  position: absolute;
  left: 0;
  width: 8rpx;
  height: 36rpx;
  border-radius: 999rpx;
  background: #c7442e;
  content: "";
}

.dish-scroll {
  height: 100%;
  background: #fffdf8;
}

.dish-section-head {
  position: sticky;
  top: 0;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  background: #fffdf8;
  padding: 18rpx 18rpx 12rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 900;
}

.dish-list {
  display: grid;
  gap: 2rpx;
  padding: 0 18rpx 12rpx;
}

.dish-scroll-spacer {
  height: calc(164rpx + env(safe-area-inset-bottom));
}

.dish-card {
  display: grid;
  grid-template-columns: 132rpx minmax(0, 1fr);
  gap: 16rpx;
  border-bottom: 1rpx solid #f0e6d8;
  padding: 18rpx 0;
}

.dish-icon {
  display: grid;
  width: 132rpx;
  height: 132rpx;
  place-items: center;
  border-radius: 16rpx;
  background: #f4efe4;
  font-size: 54rpx;
}

.dish-main {
  display: grid;
  min-width: 0;
  gap: 8rpx;
}

.dish-name {
  font-size: 29rpx;
  font-weight: 900;
  line-height: 1.25;
}

.dish-desc {
  display: -webkit-box;
  overflow: hidden;
  line-height: 1.35;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.dish-meta {
  display: flex;
  gap: 12rpx;
}

.dish-bottom {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 10rpx;
}

.price,
.cart-price {
  color: #c7442e;
  font-size: 34rpx;
  font-weight: 900;
}

.dish-tag {
  margin-left: 8rpx;
  border-radius: 999rpx;
  background: #fff1ed;
  color: #c7442e;
  font-size: 20rpx;
  font-weight: 700;
  padding: 3rpx 8rpx;
}

.add-button {
  min-width: 104rpx;
  min-height: 54rpx;
  border: 0;
  border-radius: 999rpx;
  background: #c7442e;
  color: #fff;
  font-size: 24rpx;
}

.cart-bar {
  position: fixed;
  right: 20rpx;
  bottom: calc(22rpx + env(safe-area-inset-bottom));
  left: 20rpx;
  z-index: 10;
  display: grid;
  grid-template-columns: 92rpx minmax(0, 1fr) 188rpx;
  align-items: center;
  gap: 16rpx;
  min-height: 96rpx;
  border-radius: 999rpx;
  background: #211f1b;
  box-shadow: 0 16rpx 42rpx rgba(43, 35, 24, 0.22);
  padding: 10rpx 12rpx;
}

.cart-bubble {
  position: relative;
  display: grid;
  width: 76rpx;
  height: 76rpx;
  place-items: center;
  border-radius: 999rpx;
  background: #c7442e;
  color: #fff;
  font-size: 34rpx;
}

.cart-count {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 30rpx;
  height: 30rpx;
  border-radius: 999rpx;
  background: #fff;
  color: #c7442e;
  font-size: 20rpx;
  font-weight: 900;
  line-height: 30rpx;
  text-align: center;
}

.cart-summary {
  min-width: 0;
}

.cart-tip {
  color: #cfc7bb;
}

.checkout-button {
  min-height: 72rpx;
  border: 0;
  border-radius: 999rpx;
  background: #f4c15d;
  color: #211f1b;
  font-size: 28rpx;
  font-weight: 900;
}

.cart-mask,
.modal-mask {
  position: fixed;
  inset: 0;
  z-index: 20;
  display: flex;
  align-items: flex-end;
  background: rgba(0, 0, 0, 0.45);
}

.cart-panel,
.spec-modal {
  width: 100%;
  max-height: 78vh;
  overflow-y: auto;
  border-radius: 28rpx 28rpx 0 0;
  background: #fffdf8;
  padding: 24rpx;
}

.cart-panel-head,
.cart-row,
.modal-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.cart-row {
  border-bottom: 1rpx solid #eadfce;
  padding: 16rpx 0;
}

.cart-info {
  min-width: 0;
}

.cart-name {
  font-weight: 900;
}

.cart-price-line {
  margin-top: 6rpx;
  color: #c7442e;
  font-weight: 900;
}

.cart-actions {
  display: grid;
  grid-template-columns: auto 48rpx 36rpx 48rpx;
  align-items: center;
  gap: 8rpx;
}

.delete-button,
.qty-button {
  display: grid;
  min-width: 48rpx;
  height: 48rpx;
  place-items: center;
  border: 1rpx solid #ded8ca;
  border-radius: 999rpx;
  background: #fff;
  color: #706c63;
  font-size: 22rpx;
  line-height: 48rpx;
  padding: 0;
}

.delete-button {
  min-width: 72rpx;
  color: #c7442e;
}

.qty-text {
  text-align: center;
  font-weight: 900;
}

.cart-empty {
  color: #706c63;
  padding: 32rpx 0;
  text-align: center;
}

.cart-panel-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  border-top: 1rpx solid #eadfce;
  padding-top: 18rpx;
}

.spec-group {
  margin-bottom: 18rpx;
}

.modal-head {
  align-items: flex-start;
  margin-bottom: 18rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 900;
}

.spec-options {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
  margin-top: 10rpx;
}

.spec-options button {
  min-height: 64rpx;
  border: 1rpx solid #ded8ca;
  background: #fff;
}

.spec-options button.active {
  border-color: #c7442e;
  background: #c7442e;
  color: #fff;
}

.add-configured {
  width: 100%;
  min-height: 84rpx;
  border: 0;
  border-radius: 16rpx;
  background: #c7442e;
  color: #fff;
  font-weight: 900;
}

.theme-dark {
  background: #11130f;
  color: #f7f1e7;
}

.theme-dark .shop-head {
  background: linear-gradient(180deg, #1f211c, #11130f);
}

.theme-dark .shop-subtitle,
.theme-dark .section-subtitle,
.theme-dark .dish-desc,
.theme-dark .dish-meta,
.theme-dark .cart-tip,
.theme-dark .cart-spec,
.theme-dark .modal-subtitle,
.theme-dark .field-label,
.theme-dark .cart-empty {
  color: #aaa397;
}

.theme-dark .theme-toggle {
  border-color: rgba(244, 193, 93, 0.35);
  background: #f4c15d;
  color: #211f1b;
}

.theme-dark .shop-badge,
.theme-dark .sort-chip,
.theme-dark .search-box,
.theme-dark .cart-panel,
.theme-dark .spec-modal {
  background: #24261f;
  color: #ffad91;
}

.theme-dark .search-box input {
  color: #f7f1e7;
}

.theme-dark .mode-tabs {
  background: #1a1c17;
}

.theme-dark .mode-tabs button {
  color: #aaa397;
}

.theme-dark .mode-tabs button.active,
.theme-dark .category-item.active::before,
.theme-dark .add-button,
.theme-dark .add-configured,
.theme-dark .spec-options button.active {
  background: #e85d43;
  color: #fffaf2;
}

.theme-dark .menu-shell,
.theme-dark .dish-scroll,
.theme-dark .dish-section-head,
.theme-dark .category-item.active {
  background: #181a16;
}

.theme-dark .menu-shell,
.theme-dark .dish-card,
.theme-dark .cart-row,
.theme-dark .cart-panel-foot {
  border-color: #39382f;
}

.theme-dark .category-rail {
  background: #20221c;
}

.theme-dark .category-item {
  color: #aaa397;
}

.theme-dark .category-item.active,
.theme-dark .price,
.theme-dark .cart-price,
.theme-dark .cart-price-line,
.theme-dark .delete-button {
  color: #ffad91;
}

.theme-dark .dish-icon {
  background: #26291f;
}

.theme-dark .dish-tag {
  background: rgba(232, 93, 67, 0.16);
  color: #ffad91;
}

.theme-dark .cart-bar {
  background: #070806;
  box-shadow: 0 16rpx 42rpx rgba(0, 0, 0, 0.38);
}

.theme-dark .cart-count {
  background: #24261f;
  color: #ffad91;
}

.theme-dark .checkout-button {
  background: #f4c15d;
  color: #211f1b;
}

.theme-dark .delete-button,
.theme-dark .qty-button,
.theme-dark .spec-options button {
  border-color: #39382f;
  background: #24261f;
  color: #f7f1e7;
}
