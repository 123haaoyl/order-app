.page {
  min-height: 100vh;
  padding: 20rpx 20rpx 136rpx;
  background: #f6f4ef;
}

.address-card,
.order-card,
.remark-card,
.pay-card {
  margin-bottom: 18rpx;
  border-radius: 18rpx;
  background: #fffdf8;
  padding: 22rpx;
}

.mode-tabs {
  display: grid;
  grid-template-columns: 1fr 1fr;
  overflow: hidden;
  border-radius: 999rpx;
  background: #ebe4d8;
  padding: 4rpx;
  margin-bottom: 18rpx;
}

.mode-tabs button {
  min-height: 62rpx;
  border: 0;
  border-radius: 999rpx;
  background: transparent;
  color: #706c63;
}

.mode-tabs button.active,
.submit-button {
  background: #c7442e;
  color: #fff;
}

.target-box,
.pay-card,
.fee-row,
.submit-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.target-box.vertical {
  display: grid;
}

.target-title,
.goods-spec,
.goods-count,
.pay-label,
.submit-tip {
  color: #706c63;
  font-size: 24rpx;
}

.target-value,
.shop-title,
.goods-name,
.remark-title,
.pay-method {
  font-weight: 900;
}

input,
textarea {
  width: 100%;
  min-height: 72rpx;
  margin-top: 8rpx;
  border-radius: 12rpx;
  background: #f8f4ee;
  padding: 0 18rpx;
}

textarea {
  min-height: 136rpx;
  padding-top: 16rpx;
}

.shop-title {
  margin-bottom: 14rpx;
  font-size: 30rpx;
}

.goods-list {
  display: grid;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.goods-row {
  display: grid;
  grid-template-columns: 72rpx minmax(0, 1fr) auto;
  gap: 14rpx;
  align-items: start;
}

.goods-icon {
  display: grid;
  width: 72rpx;
  height: 72rpx;
  place-items: center;
  border-radius: 12rpx;
  background: #f4efe4;
  font-size: 34rpx;
}

.goods-main {
  display: grid;
  gap: 4rpx;
}

.goods-price,
.payable {
  color: #c7442e;
  font-weight: 900;
}

.fee-row {
  border-top: 1rpx solid #eadfce;
  color: #706c63;
  font-size: 26rpx;
  padding-top: 14rpx;
}

.pay-tag {
  border-radius: 999rpx;
  background: #fff1ed;
  color: #c7442e;
  font-size: 24rpx;
  padding: 6rpx 14rpx;
}

.submit-bar {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  min-height: 112rpx;
  background: #fffdf8;
  box-shadow: 0 -10rpx 32rpx rgba(43, 35, 24, 0.12);
  padding: 16rpx 20rpx calc(16rpx + env(safe-area-inset-bottom));
}

.payable {
  font-size: 42rpx;
}

.submit-button {
  width: 240rpx;
  min-height: 78rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 900;
}
