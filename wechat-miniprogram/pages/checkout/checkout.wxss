.page {
  min-height: 100vh;
  padding: 20rpx 20rpx 136rpx;
  background: #f6f4ef;
  color: #211f1b;
}

.address-card,
.order-card,
.remark-card,
.pay-card {
  margin-bottom: 18rpx;
  border-radius: 18rpx;
  background: #fffdf8;
  padding: 22rpx;
}

.checkout-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 18rpx;
}

.checkout-title {
  font-size: 38rpx;
  font-weight: 900;
}

.checkout-subtitle {
  color: #706c63;
  font-size: 24rpx;
}

.theme-toggle {
  flex: 0 0 auto;
  min-width: 88rpx;
  min-height: 52rpx;
  margin: 0;
  border: 1rpx solid rgba(33, 31, 27, 0.16);
  border-radius: 999rpx;
  background: #211f1b;
  color: #fffaf2;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 52rpx;
  padding: 0 16rpx;
}

.theme-toggle::after {
  border: 0;
}

.mode-tabs {
  display: grid;
  grid-template-columns: 1fr 1fr;
  overflow: hidden;
  border-radius: 999rpx;
  background: #ebe4d8;
  padding: 4rpx;
  margin-bottom: 18rpx;
}

.mode-tabs button {
  min-height: 62rpx;
  border: 0;
  border-radius: 999rpx;
  background: transparent;
  color: #706c63;
}

.mode-tabs button.active,
.submit-button {
  background: #c7442e;
  color: #fff;
}

.target-box,
.pay-card,
.fee-row,
.submit-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.target-box.vertical {
  display: grid;
}

.target-title,
.goods-spec,
.goods-count,
.pay-label,
.submit-tip {
  color: #706c63;
  font-size: 24rpx;
}

.target-value,
.shop-title,
.goods-name,
.remark-title,
.pay-method {
  font-weight: 900;
}

input,
textarea {
  width: 100%;
  min-height: 72rpx;
  margin-top: 8rpx;
  border-radius: 12rpx;
  background: #f8f4ee;
  padding: 0 18rpx;
}

textarea {
  min-height: 136rpx;
  padding-top: 16rpx;
}

.shop-title {
  margin-bottom: 14rpx;
  font-size: 30rpx;
}

.goods-list {
  display: grid;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.goods-row {
  display: grid;
  grid-template-columns: 72rpx minmax(0, 1fr) auto;
  gap: 14rpx;
  align-items: start;
}

.goods-icon {
  display: grid;
  width: 72rpx;
  height: 72rpx;
  place-items: center;
  border-radius: 12rpx;
  background: #f4efe4;
  font-size: 34rpx;
}

.goods-main {
  display: grid;
  gap: 4rpx;
}

.goods-price,
.payable {
  color: #c7442e;
  font-weight: 900;
}

.fee-row {
  border-top: 1rpx solid #eadfce;
  color: #706c63;
  font-size: 26rpx;
  padding-top: 14rpx;
}

.pay-tag {
  border-radius: 999rpx;
  background: #fff1ed;
  color: #c7442e;
  font-size: 24rpx;
  padding: 6rpx 14rpx;
}

.submit-bar {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  min-height: 112rpx;
  background: #fffdf8;
  box-shadow: 0 -10rpx 32rpx rgba(43, 35, 24, 0.12);
  padding: 16rpx 20rpx calc(16rpx + env(safe-area-inset-bottom));
}

.payable {
  font-size: 42rpx;
}

.submit-button {
  width: 240rpx;
  min-height: 78rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 900;
}

.theme-dark {
  background: #11130f;
  color: #f7f1e7;
}

.theme-dark .address-card,
.theme-dark .order-card,
.theme-dark .remark-card,
.theme-dark .pay-card,
.theme-dark .submit-bar {
  background: #181a16;
}

.theme-dark .mode-tabs {
  background: #24261f;
}

.theme-dark .mode-tabs button {
  color: #aaa397;
}

.theme-dark .mode-tabs button.active,
.theme-dark .submit-button {
  background: #e85d43;
  color: #fffaf2;
}

.theme-dark .theme-toggle {
  border-color: rgba(244, 193, 93, 0.35);
  background: #f4c15d;
  color: #211f1b;
}

.theme-dark .target-title,
.theme-dark .checkout-subtitle,
.theme-dark .goods-spec,
.theme-dark .goods-count,
.theme-dark .pay-label,
.theme-dark .submit-tip,
.theme-dark .fee-row {
  color: #aaa397;
}

.theme-dark input,
.theme-dark textarea {
  background: #24261f;
  color: #f7f1e7;
}

.theme-dark .goods-icon {
  background: #26291f;
}

.theme-dark .fee-row {
  border-color: #39382f;
}

.theme-dark .goods-price,
.theme-dark .payable {
  color: #ffad91;
}

.theme-dark .pay-tag {
  background: rgba(232, 93, 67, 0.16);
  color: #ffad91;
}
